{
  "name": "tasknotes-electron",
  "version": "1.1.2",
  "description": "Fast local task and notes manager with Electron and JSON file persistence",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "rm -rf dist && electron-builder",
    "build:mac": "rm -rf dist && electron-builder --mac dmg zip",
    "build:win": "electron-builder --win nsis portable"
  },
  "keywords": [
    "electron",
    "tasks",
    "notes",
    "json"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.damianobellucci.tasknotes",
    "productName": "TaskNotes",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "TaskNotes"
    }
  },
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^25.1.8",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1009.0",
    "dotenv": "^17.3.1"
  }
}
